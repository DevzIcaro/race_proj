model Inscricao{
    id String @id @default(uuid())
    num_inscricao Int
    desc_inscricao String?

    piloto Piloto @relation(fields: [pilotoId], references: [id])
    pilotoId String

    carro Carro @relation(fields: [carroId], references: [id])
    carroId String

    corrida Corrida @relation(fields: [corridaId], references:[id])
    corridaId String
}